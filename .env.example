# Server
PORT=3000

# Scan behavior
MIN_BALANCE_USDT=3
SCAN_INTERVAL_MS=30000
# Comma-separated symbols (used only if BINANCE_REAL=1)
SCAN_SYMBOLS=PEPEUSDT,WIFUSDT,DOGEUSDT,BONKUSDT,SHIBUSDT

# Feature adapter
# Set to "1" to attempt real Binance fetching (stub requires BINANCE_BASE_URL).
BINANCE_REAL=0
BINANCE_BASE_URL=
