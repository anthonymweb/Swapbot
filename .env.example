# ─────────────────────────────────────────────
#  SWAPBOT v2.0 — Environment Configuration
#  Copy this to .env and fill in your values
# ─────────────────────────────────────────────

# BINANCE
TESTNET=true
API_KEY=your_binance_api_key_here
API_SECRET=your_binance_secret_here

# TELEGRAM
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHANNEL_ID=@YourChannelUsername
SIGNALS_ENABLED=true

# GITHUB (for Mini App data updates)
GITHUB_USERNAME=your_github_username
GITHUB_REPO=swapbot

# STRATEGY
CONSERVATIVE_RATIO=0.80
SNIPER_RATIO=0.20
CONSERVATIVE_TRADE_SIZE=0.25
SNIPER_TRADE_SIZE=0.50
TRAILING_STOP=0.10
CONSERVATIVE_STOP_LOSS=0.05
CONSERVATIVE_TAKE_PROFIT=0.08
SNIPER_PARTIAL_PROFIT=1.00
SNIPER_FULL_PROFIT=3.00
DRAWDOWN_LIMIT=0.15
SCAN_INTERVAL_CONSERVATIVE=60
SCAN_INTERVAL_SNIPER=30
MIN_SNIPER_SCORE=70
MIN_VOLUME_MULTIPLIER=3
